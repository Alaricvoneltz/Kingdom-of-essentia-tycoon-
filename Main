local FileName = "AlaricHub_KeyAuth.txt"
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local function checkKeyWithKeyForge(targetKey)
    if not targetKey or targetKey == "" or targetKey == "Paste KF-XXXX-XXXX here" then 
        return false 
    end
    
    local success, err = pcall(function()
        (loadstring or load)(game:HttpGet("https://www.keyforge.win/v1/load/cmr4rklu700000akxd5babrtw?e=1&script=cmr4se8du000004jvl4xt95zn&key=" .. targetKey .. "&_cb=" .. tostring(os.clock()) .. "-" .. tostring(math.random(0, 2147483647))))()
    end)
    return success
end

if isfile and readfile and isfile(FileName) then
    local savedKey = readfile(FileName)
    if savedKey and savedKey ~= "" then
        Rayfield:Notify({
            Title = "Auto Auth",
            Content = "Verifying key...",
            Duration = 3
        })
        
        if checkKeyWithKeyForge(savedKey) then
            return
        end
    end
end

local KeyWindow = Rayfield:CreateWindow({
    Name = "Alaric Hub | Key System",
    LoadingTitle = "Checking System...",
    LoadingSubtitle = "by Alaric",
    ConfigurationSaving = { Enabled = false }
})

local KeyTab = KeyWindow:CreateTab("Verification", 4483362458)
local UserKey = ""

KeyTab:CreateInput({
    Name = "Enter Your Key",
    PlaceholderText = "Paste KF-XXXX-XXXX here",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        UserKey = Text
    end,
})

KeyTab:CreateButton({
    Name = "Check & Verify Key",
    Callback = function()
        if UserKey == "" or UserKey == "Paste KF-XXXX-XXXX here" then
            Rayfield:Notify({
                Title = "Error",
                Content = "Please enter your key first!",
                Duration = 3
            })
            return
        end
        
        Rayfield:Notify({
            Title = "Checking",
            Content = "Verifying key...",
            Duration = 2
        })
        
        if checkKeyWithKeyForge(UserKey) then
            Rayfield:Notify({
                Title = "Success",
                Content = "Key Valid! Enjoy Alaric Hub.",
                Duration = 3
            })
            
            if writefile then
                writefile(FileName, UserKey)
            end
            
            task.wait(1)
            Rayfield:Destroy()
        else
            Rayfield:Notify({
                Title = "Verification Failed",
                Content = "Invalid, expired, or unregistered key!",
                Duration = 5
            })
        end
    end,
})

KeyTab:CreateButton({
    Name = "Join Discord to Get Key",
    Callback = function()
        setclipboard("https://discord.gg/meCAQTUna")
        Rayfield:Notify({
            Title = "Link Copied",
            Content = "Discord invite link has been copied to clipboard!",
            Duration = 3
        })
    end,
})
