VerifyBtn.MouseButton1Click:Connect(function()
    local inputKey = KeyInput.Text
    
    if inputKey == "" then
        VerifyBtn.Text = "KEY CANNOT BE EMPTY!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        task.wait(1.5)
        VerifyBtn.Text = "VERIFY KEY"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 120)
        return
    end
    
    VerifyBtn.Text = "CHECKING DATABASE..."
    VerifyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    VerifyBtn.BackgroundColor3 = Color3.fromRGB(100, 80, 200)
    
    local success, err = pcall(function()
        (loadstring or load)(game:HttpGet("https://www.keyforge.win/v1/load/cmr4rklu700000akxd5babrtw?e=1&script=cmr4se8du000004jvl4xt95zn&key=" .. inputKey .. "&_cb=" .. tostring(os.clock()) .. "-" .. tostring(math.random(0, 2147483647))))()
    end)
    
    if success then
        VerifyBtn.Text = "ACCESS GRANTED!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
        VerifyBtn.TextColor3 = Color3.fromRGB(10, 10, 20)
        task.wait(1)
        ScreenGui:Destroy()
    else
        VerifyBtn.Text = "INVALID / EXPIRED KEY!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
        VerifyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        task.wait(2)
        VerifyBtn.Text = "VERIFY KEY"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 120)
        VerifyBtn.TextColor3 = Color3.fromRGB(10, 10, 20)
    end
end)

GetKeyBtn.MouseButton1Click:Connect(function()
    setclipboard("https://discord.gg/meCAQTUna") -- Menyalin Link Discord
    GetKeyBtn.Text = "DISCORD LINK COPIED!"
    GetKeyBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    task.wait(1.5)
    GetKeyBtn.Text = "JOIN DISCORD TO GET KEY"
    GetKeyBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
end)
